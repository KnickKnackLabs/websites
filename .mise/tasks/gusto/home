#!/usr/bin/env bash
#MISE description="View Gusto dashboard (tasks, payments, upcoming)"
#USAGE flag "--keep" help="Keep the browser open after extracting data"
#USAGE flag "--site <site>" help="Auth session to load" default="gusto.com"
#USAGE flag "--json" help="Output raw JSON"
#USAGE flag "--record" help="Record page artifacts for test fixtures"

set -e

PROJECT_DIR="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"

# --- Recording setup ---
if [ "${usage_record:-false}" = "true" ]; then
  RECORD_DIR="$PROJECT_DIR/test/fixtures/$(date +%Y%m%d-%H%M%S)"
  export WEBSITES_RECORD_DIR="$RECORD_DIR"
  echo "Recording artifacts to: $RECORD_DIR" >&2
fi

# --- Browser setup ---
source "$PROJECT_DIR/lib/browser.sh"
setup_browser "${usage_keep:-false}" "${usage_site:-gusto.com}"

# --- Run the Patchright script ---
OUTPUT=$(browser run "${BROWSER_ARGS[@]}" "$PROJECT_DIR/scripts/gusto/home.mjs" 2>&1 | grep '^{') || true

if [ -z "$OUTPUT" ]; then
  echo "Failed to fetch Gusto dashboard." >&2
  exit 1
fi

if [ "${usage_json:-false}" = "true" ]; then
  echo "$OUTPUT"
else
  echo ""
  echo "$(echo "$OUTPUT" | jq -r '.greeting')"
  echo ""

  TASK_COUNT=$(echo "$OUTPUT" | jq '.tasks | length')
  if [ "$TASK_COUNT" -gt 0 ]; then
    echo "Tasks ($TASK_COUNT):"
    echo "$OUTPUT" | jq -r '.tasks[]' | while read -r task; do
      echo "  - $task"
    done
    echo ""
  fi

  SIDEBAR_COUNT=$(echo "$OUTPUT" | jq '.sidebar | length')
  if [ "$SIDEBAR_COUNT" -gt 0 ]; then
    echo "$OUTPUT" | jq -r '.sidebar[] | "\(.heading):\n  \(.body)\n"'
  fi
fi
