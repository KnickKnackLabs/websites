#!/usr/bin/env bash
#MISE description="Open a GitHub issue in the browser"
#USAGE arg "<issue>" help="Issue reference (owner/repo#number or full URL)"
#USAGE flag "--keep" help="Keep the browser open after loading"
#USAGE flag "--browser <browser>" help="Persistent browser ID to use"

set -euo pipefail

ISSUE="${usage_issue}"

# Parse owner/repo#number format
if [[ "$ISSUE" =~ ^https:// ]]; then
  URL="$ISSUE"
elif [[ "$ISSUE" =~ ^([^#]+)#([0-9]+)$ ]]; then
  REPO="${BASH_REMATCH[1]}"
  NUMBER="${BASH_REMATCH[2]}"
  URL="https://github.com/${REPO}/issues/${NUMBER}"
else
  echo "ERROR: expected owner/repo#number or URL, got: $ISSUE" >&2
  exit 1
fi

BROWSER_ARGS=()
if [ -n "${usage_browser:-}" ]; then
  BROWSER_ARGS+=(--browser "${usage_browser}")
elif [ "${usage_keep:-false}" = "true" ]; then
  BROWSER_ID=$(shimmer browser:launch --headed 2>/dev/null | grep -o 'browser-[a-z0-9-]*' || true)
  if [ -n "$BROWSER_ID" ]; then
    BROWSER_ARGS+=(--browser "$BROWSER_ID")
    echo "Browser: $BROWSER_ID (will stay open)" >&2
  else
    BROWSER_ARGS+=(--headed)
  fi
fi

shimmer browser:goto "${BROWSER_ARGS[@]}" "$URL"

echo "Opened: $URL" >&2
