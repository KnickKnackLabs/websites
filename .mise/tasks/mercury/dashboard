#!/usr/bin/env bash
#MISE description="View Mercury dashboard (balances, accounts)"
#USAGE flag "--keep" help="Keep the browser open after extracting data"
#USAGE flag "--site <site>" help="Auth session to load" default="mercury.com"
#USAGE flag "--json" help="Output raw JSON"
#USAGE flag "--record" help="Record page artifacts for test fixtures"

set -e

PROJECT_DIR="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"

if [ "${usage_record:-false}" = "true" ]; then
  export WEBSITES_RECORD_DIR="$PROJECT_DIR/test/fixtures/$(date +%Y%m%d-%H%M%S)"
  echo "Recording artifacts to: $WEBSITES_RECORD_DIR" >&2
fi

# --- Browser setup ---
source "$PROJECT_DIR/lib/browser.sh"
setup_browser "${usage_keep:-false}" "${usage_site:-mercury.com}"

RAW_OUTPUT=$(browser run "${BROWSER_ARGS[@]}" "$PROJECT_DIR/scripts/mercury/dashboard.mjs" 2>&1) || {
  echo "$RAW_OUTPUT" >&2
  exit 1
}

OUTPUT=$(echo "$RAW_OUTPUT" | grep '^{') || true

if [ -z "$OUTPUT" ]; then
  echo "$RAW_OUTPUT" >&2
  echo "Failed to fetch Mercury dashboard." >&2
  exit 1
fi

if [ "${usage_json:-false}" = "true" ]; then
  echo "$OUTPUT"
else
  echo ""
  echo "$(echo "$OUTPUT" | jq -r '.greeting // "Mercury"')"
  echo ""
  BALANCE=$(echo "$OUTPUT" | jq -r '.balance // ""')
  [ -n "$BALANCE" ] && echo "$BALANCE" | head -3 && echo ""
  CREDIT=$(echo "$OUTPUT" | jq -r '.creditCard // ""')
  [ -n "$CREDIT" ] && echo "$CREDIT" | head -3 && echo ""
fi
