#!/usr/bin/env bash
#MISE description="Activate Mercury access from an invite email or URL"
#USAGE flag "--email-id <id>" help="Email ID containing the Mercury invite"
#USAGE flag "--invite-url <url>" help="Explicit Mercury invite URL"
#USAGE flag "--password <password>" help="Optional password to prefill in Mercury"
#USAGE flag "--keep" help="Keep the browser open after saving auth"
#USAGE flag "--record" help="Record page artifacts for test fixtures"

set -euo pipefail

PROJECT_DIR="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}"
EMAIL_ID="${usage_email_id:-}"
INVITE_URL="${usage_invite_url:-}"
PASSWORD="${usage_password:-}"
KEEP="${usage_keep:-false}"

if [ "${usage_record:-false}" = "true" ]; then
  export WEBSITES_RECORD_DIR="$PROJECT_DIR/test/fixtures/$(date +%Y%m%d-%H%M%S)"
  echo "Recording artifacts to: $WEBSITES_RECORD_DIR" >&2
fi

if [ -z "$INVITE_URL" ] && [ -n "$EMAIL_ID" ]; then
  EMAIL_TEXT=$(emails read "$EMAIL_ID")
  INVITE_URL=$(cd "$PROJECT_DIR" && EMAIL_TEXT="$EMAIL_TEXT" node --input-type=module <<'EOF'
import { extractInviteUrl } from './scripts/mercury/auth.mjs';
const text = process.env.EMAIL_TEXT || '';
const url = extractInviteUrl(text);
if (url) console.log(url);
EOF
)
fi

if [ -z "$INVITE_URL" ]; then
  echo "Mercury invite URL not found." >&2
  echo "Pass --invite-url explicitly or use --email-id with a Mercury invite email." >&2
  exit 1
fi

BROWSER_ID=$(browser launch --headed)
echo "Browser: $BROWSER_ID" >&2

SCRIPT_ARGS=("$INVITE_URL")
if [ -n "$PASSWORD" ]; then
  SCRIPT_ARGS+=(--password "$PASSWORD")
fi

if ! browser run -b "$BROWSER_ID" "$PROJECT_DIR/scripts/mercury/activate.mjs" -- "${SCRIPT_ARGS[@]}"; then
  echo "Mercury activation failed." >&2
  browser close "$BROWSER_ID" 2>/dev/null || true
  exit 1
fi

browser save-auth mercury.com -b "$BROWSER_ID" >/dev/null

echo "Mercury auth saved for mercury.com." >&2

if [ "$KEEP" = "true" ]; then
  echo "Browser left open: $BROWSER_ID" >&2
else
  browser close "$BROWSER_ID" >/dev/null 2>&1 || true
fi

echo "Mercury activation complete."
